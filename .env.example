# ---- Database (MySQL) ----
# Local MySQL example:
#   mysql://user:password@localhost:3306/powerapps_blog
# PlanetScale: copy the connection string from the dashboard (and enable
# relationMode = "prisma" in prisma/schema.prisma).
DATABASE_URL="mysql://user:password@localhost:3306/powerapps_blog"

# ---- Auth ----
# Long random string. Generate one with:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret"
# Token lifetime (e.g. 7d, 12h)
JWT_EXPIRES_IN="7d"

# ---- Seed admin (used by prisma/seed.ts) ----
SEED_ADMIN_EMAIL="admin@powerapps.blog"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# ---- API server ----
API_PORT="4000"
# Comma-separated list of origins allowed to call the API (the public site + admin).
# In dev, any localhost port is also allowed automatically.
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175"

# ---- Cloudinary (media uploads) ----
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ---- Email notifications (new-comment moderation alerts) ----
# Optional. If unset, comments still work — you just won't get email alerts.
# Any SMTP provider works. Gmail example (needs an App Password, not your login):
#   SMTP_HOST="smtp.gmail.com"  SMTP_PORT="587"  SMTP_USER="you@gmail.com"
#   SMTP_PASS="your-16-char-app-password"   (https://myaccount.google.com/apppasswords)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"          # true for port 465, false for 587 (STARTTLS)
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="PowerApps.blog <no-reply@powerapps.blog>"
# Where moderation alerts are sent. Defaults to SMTP_USER if unset.
NOTIFY_EMAIL=""
# Used to build the "Review" link in notification emails.
SITE_URL="https://www.powerapps.blog"

# ---- Frontend (Vite) ----
VITE_API_URL="http://localhost:4000"
VITE_SITE_URL="http://localhost:3000"
